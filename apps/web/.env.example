# ===========================================
# Newndy Board - Web 환경 변수 템플릿
# ===========================================
# 이 파일을 복사해서 .env.local로 만든 후 값을 채워주세요.
# cp .env.example .env.local
#
# 주의: .env.local은 Git에 올라가지 않습니다.
# ===========================================

# --- 앱 설정 ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API 서버 ---
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- 인증 (Sprint 2에서 설정 예정) ---
